# OpenClaw Automation — Environment Variables
# Copy to .env and fill in your values

# Discord Webhooks
DISCORD_STANDUP_WEBHOOK_URL=
DISCORD_BLOCKER_WEBHOOK_URL=
DISCORD_HEALTH_WEBHOOK_URL=
DISCORD_SUMMARY_WEBHOOK_URL=

# Timezone (default: Europe/Warsaw)
CRON_TIMEZONE=Europe/Warsaw

# Dry run mode (true = don't actually send notifications)
CRON_DRY_RUN=false
